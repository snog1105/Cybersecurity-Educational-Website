# Copy this file to `.env` for local development and fill in values.
# Do NOT commit your real API keys to version control.

# IPQualityScore API key (required)
IPQS_API_KEY=your_ipqualityscore_api_key_here

# Optional: CORS origin the API should allow during development
CORS_ORIGIN=http://localhost:4321

# Optional: Port to run the server locally
PORT=5000
 
# Optional: Public API base URL used by the frontend (set to your Render service url)
# Example: PUBLIC_API_URL=https://your-service.onrender.com
PUBLIC_API_URL=
