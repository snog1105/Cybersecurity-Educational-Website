---
import HomeButton from '../components/HomeButton.astro';
import PlayfulLayout from '../layouts/PlayfulLayout.astro';
---

<PlayfulLayout>
  <div>
    <HomeButton />
    <h1 class="site-title">Cryptography</h1>

    <div class="media" style="height:506px;max-width:900px;margin:12px auto;">
      <iframe width="100%" height="100%" src="https://www.youtube.com/embed/_STHiF-Lue4" title="Cryptography video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>

    <p class="lead">Introduces basic cryptography concepts: symmetric/asymmetric encryption, hashing, and real-world uses.</p>

    <div class="video-actions" style="display:flex;gap:12px;justify-content:center;margin-top:12px;">
      <a class="btn secondary" href="/phishing">Back</a>
      <a class="btn" href="/network-security">Next: Network Security</a>
    </div>
  </div>
</PlayfulLayout>
