---
import HomeButton from '../components/HomeButton.astro';
import PlayfulLayout from '../layouts/PlayfulLayout.astro';

const title = 'Cybersecurity Resources & Further Reading | HackProof';
const description = 'Trusted external resources for reporting scams, learning more about cybersecurity, and staying safe online beyond the HackProof modules.';
---

<PlayfulLayout title={title} description={description}>
  <div style="max-width:800px;margin:0 auto;text-align:left;">
    <HomeButton />
    <h1 class="site-title">Resources</h1>
    <p class="lead">HackProof's modules are a starting point. These trusted external resources go deeper on specific topics and are useful if you need to report a threat or want to keep learning.</p>

    <section class="card" style="margin-bottom:20px;">
      <h2 class="section-title">Report a Threat</h2>
      <ul>
        <li><a href="https://www.ic3.gov/" target="_blank" rel="noopener noreferrer">FBI Internet Crime Complaint Center (IC3)</a>: report phishing, scams, and online fraud in the U.S.</li>
        <li><a href="https://reportphishing.apwg.org/" target="_blank" rel="noopener noreferrer">Anti-Phishing Working Group</a>: forward suspicious phishing emails for analysis.</li>
      </ul>
    </section>

    <section class="card" style="margin-bottom:20px;">
      <h2 class="section-title">Learn More</h2>
      <ul>
        <li><a href="https://www.cisa.gov/topics/cybersecurity-best-practices" target="_blank" rel="noopener noreferrer">CISA Cybersecurity Best Practices</a>: guidance from the U.S. Cybersecurity and Infrastructure Security Agency.</li>
        <li><a href="https://staysafeonline.org/" target="_blank" rel="noopener noreferrer">National Cybersecurity Alliance: Stay Safe Online</a>: plain-language safety tips for individuals and families.</li>
        <li><a href="https://www.nist.gov/cyberframework" target="_blank" rel="noopener noreferrer">NIST Cybersecurity Framework</a>: the standard reference framework used across the security industry.</li>
      </ul>
    </section>

    <section class="card">
      <h2 class="section-title">Keep Practicing on HackProof</h2>
      <p>Ready to apply what you've read? Head back to <a href="/learning">Learning Modules</a> to review core concepts, try the <a href="/content-analysis">Content Analyzer</a> on a real suspicious message, or test yourself with the <a href="/quizzes">Quizzes</a>.</p>
    </section>
  </div>
</PlayfulLayout>
