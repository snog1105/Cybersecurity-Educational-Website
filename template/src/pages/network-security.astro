---
import HomeButton from '../components/HomeButton.astro';
import PlayfulLayout from '../layouts/PlayfulLayout.astro';

const title = 'Network Security Fundamentals | HackProof';
const description = 'Learn how networks get attacked and defended, from firewalls to intrusion detection, in this hands-on introduction to network security.';
---

<PlayfulLayout title={title} description={description}>
  <div>
    <HomeButton />
    <h1 class="site-title">Network Security</h1>

    <div class="media" style="height:506px;max-width:900px;margin:12px auto;">
      <iframe width="100%" height="100%" src="https://www.youtube.com/embed/Tn5UzCPxWCo" title="Network Security video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>

    <p class="lead">Covers fundamentals of network security, firewalls, segmentation, and best practices for protecting networks.</p>

    <div class="video-actions" style="display:flex;gap:12px;justify-content:center;margin-top:12px;">
      <a class="btn secondary" href="/cryptography">Back</a>
      <a class="btn" href="/quizzes">Take a quiz to see what you've learned!</a>
      <a class="btn secondary" href="/">Done: Back to Home</a>
    </div>
  </div>
</PlayfulLayout>
