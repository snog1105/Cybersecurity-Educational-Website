---
import HomeButton from '../components/HomeButton.astro';
import PlayfulLayout from '../layouts/PlayfulLayout.astro';

const title = 'How to Spot Phishing Attacks | HackProof';
const description = 'Learn the tactics behind phishing emails and messages, see real-world examples, and practice identifying scams with interactive exercises.';
---

<PlayfulLayout title={title} description={description}>
  <div>
    <HomeButton />
    <h1 class="site-title">Phishing</h1>

    <div class="media" style="height:506px;max-width:900px;margin:12px auto;">
      <iframe width="100%" height="100%" src="https://www.youtube.com/embed/mptKh35KFGE" title="Phishing video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>

    <p class="lead">Explains common phishing methods, how to recognize suspicious messages, and steps to stay safe.</p>

    <div class="video-actions" style="display:flex;gap:12px;justify-content:center;margin-top:12px;">
      <a class="btn secondary" href="/malware">Back</a>
      <a class="btn" href="/cryptography">Next: Cryptography</a>
    </div>
  </div>
</PlayfulLayout>
