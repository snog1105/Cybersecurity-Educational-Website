---
import HomeButton from '../components/HomeButton.astro';
import PlayfulLayout from '../layouts/PlayfulLayout.astro';

const title = 'Cybersecurity Learning Videos | HackProof';
const description = 'Browse bite-sized video lessons on malware, phishing, cryptography, and network security — built for beginners who want practical, hands-on cyber skills.';
---

<PlayfulLayout title={title} description={description}>
  <div style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.25rem;padding:2rem;text-align:center;">
    <HomeButton />
    <h1 class="site-title">Learning Videos</h1>
    <p class="lead">Explore short videos on core cybersecurity topics. Click a card below to open the full video page.</p>

    <section style="max-width:800px;text-align:left;">
      <h2 class="section-title">Cybersecurity Fundamentals, One Topic at a Time</h2>
      <p>Each module below pairs a short video with a plain-English explanation of a core cybersecurity concept — no prior experience required. Start with Malware to understand how malicious software spreads and infects devices, then move through Phishing to learn how attackers trick people into handing over credentials or money.</p>
      <p>From there, Cryptography covers how encryption and hashing keep data private and tamper-proof, and Network Security ties it together with firewalls, segmentation, and intrusion detection. Work through the modules in order or jump straight to the topic you need, then head to the quizzes to test what you've learned.</p>
    </section>

    <div class="topic-grid">
      <div class="topic-card"><a href="/malware">Video 1: Malware</a></div>
      <div class="topic-card"><a href="/phishing">Video 2: Phishing</a></div>
      <div class="topic-card"><a href="/cryptography">Video 3: Cryptography</a></div>
      <div class="topic-card"><a href="/network-security">Video 4: Network Security</a></div>
    </div>
  </div>
</PlayfulLayout>


